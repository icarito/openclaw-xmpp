{
  "name": "@openclaw/xmpp",
  "version": "2026.7.2",
  "description": "OpenClaw XMPP channel plugin",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@openclaw/xmpp",
      "npmSpec": "@openclaw/xmpp",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.9",
      "allowInvalidConfigRecovery": true
    },
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "xmpp",
      "label": "XMPP",
      "selectionLabel": "XMPP (Jabber JID + password)",
      "detailLabel": "XMPP",
      "docsPath": "/channels/xmpp",
      "docsLabel": "xmpp",
      "blurb": "XMPP/Jabber accounts with 1:1 chat, MUC rooms, and ad-hoc commands.",
      "aliases": [
        "jabber"
      ],
      "systemImage": "message",
      "configuredState": {
        "env": {
          "allOf": [
            "XMPP_JID",
            "XMPP_PASSWORD"
          ]
        },
        "specifier": "./configured-state",
        "exportName": "hasXmppConfiguredState"
      }
    },
    "channelConfigs": {
      "xmpp": {
        "schema": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "capabilities": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "inlineButtons": {
                      "type": "string",
                      "enum": [
                        "off",
                        "dm",
                        "group",
                        "all",
                        "allowlist"
                      ]
                    }
                  }
                }
              ]
            }
          }
        },
        "label": "XMPP",
        "selectionLabel": "XMPP (Jabber JID + password)",
        "detailLabel": "XMPP",
        "docsPath": "/channels/xmpp",
        "docsLabel": "xmpp",
        "blurb": "XMPP/Jabber accounts with 1:1 chat, MUC rooms, and ad-hoc commands.",
        "systemImage": "message"
      }
    },
    "compat": {
      "pluginApi": ">=2026.7.1"
    },
    "build": {
      "openclawVersion": "2026.7.1",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": false,
      "publishToNpm": false
    }
  },
  "dependencies": {
    "@xmpp/client": "^0.13.1",
    "@xmpp/xml": "^0.13.1",
    "zod": "4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/icarito/claudio-w"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "@types/xmpp__client": "^0.14.1",
    "@types/xmpp__xml": "^0.14.0",
    "openclaw": "^2026.7.1",
    "typescript": "^7.0.2"
  }
}
