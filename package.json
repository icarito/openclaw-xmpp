{
  "name": "@openclaw/xmpp",
  "version": "2026.7.1",
  "description": "OpenClaw XMPP channel plugin",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@openclaw/xmpp",
      "npmSpec": "@openclaw/xmpp",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.9",
      "allowInvalidConfigRecovery": true
    },
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "xmpp",
      "label": "XMPP",
      "selectionLabel": "XMPP (Jabber JID + password)",
      "detailLabel": "XMPP",
      "docsPath": "/channels/xmpp",
      "docsLabel": "xmpp",
      "blurb": "XMPP/Jabber accounts with 1:1 chat, MUC rooms, and ad-hoc commands.",
      "aliases": [
        "jabber"
      ],
      "systemImage": "message",
      "configuredState": {
        "env": {
          "allOf": [
            "XMPP_JID",
            "XMPP_PASSWORD"
          ]
        },
        "specifier": "./configured-state",
        "exportName": "hasXmppConfiguredState"
      }
    },
    "compat": {
      "pluginApi": ">=2026.7.1"
    },
    "build": {
      "openclawVersion": "2026.7.1",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": false,
      "publishToNpm": false
    }
  },
  "dependencies": {
    "@xmpp/client": "^0.13.1",
    "@xmpp/xml": "^0.13.1",
    "zod": "4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/icarito/claudio-w"
  }
}
